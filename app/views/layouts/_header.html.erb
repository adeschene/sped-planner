<nav class="navbar navbar-dark bg-dark bg-gradient py-2">
  <div class="container-fluid flex-column align-items-center gap-2">
    <div class="d-flex flex-wrap gap-2 justify-content-center">
      <%= link_to month_view_path(:start_date => params[:start_date]),
            class: "btn btn-sm rounded-pill #{ request.path == month_view_path ? 'btn-light' : 'btn-outline-light' }",
            aria: { current: request.path == month_view_path ? 'page' : false } do %>
        <i class="bi bi-calendar-month me-1"></i>Month
      <% end %>
      <%= link_to week_view_path(:start_date => params[:start_date]),
            class: "btn btn-sm rounded-pill #{ request.path == week_view_path ? 'btn-light' : 'btn-outline-light' }",
            aria: { current: request.path == week_view_path ? 'page' : false } do %>
        <i class="bi bi-calendar-week me-1"></i>Week
      <% end %>
      <%= link_to day_view_path(:start_date => params[:start_date]),
            class: "btn btn-sm rounded-pill #{ request.path == day_view_path ? 'btn-light' : 'btn-outline-light' }",
            aria: { current: request.path == day_view_path ? 'page' : false } do %>
        <i class="bi bi-calendar-day me-1"></i>Day
      <% end %>
      <%= link_to timeslots_path,
            class: "btn btn-sm rounded-pill #{ request.path == timeslots_path ? 'btn-light' : 'btn-outline-light' }",
            aria: { current: request.path == timeslots_path ? 'page' : false } do %>
        <i class="bi bi-gear me-1"></i>Settings
      <% end %>

      <div class="dropdown">
        <button class="btn btn-sm rounded-pill btn-outline-light dropdown-toggle"
                type="button" data-bs-toggle="dropdown" aria-expanded="false">
          <i class="bi bi-palette me-1"></i>Theme
        </button>
        <ul class="dropdown-menu dropdown-menu-dark">
          <% [["default", "Pink (Default)"], ["garden", "Garden Greens"],
              ["citrus", "Sunny Citrus"], ["ocean", "Ocean"],
              ["wildflower", "Wildflower Meadow"]].each do |value, label| %>
            <li>
              <%= button_to label, update_theme_path,
                    method: :patch,
                    params: { theme: value },
                    class: "dropdown-item #{'active' if current_user&.theme == value}",
                    form_class: "d-block border-0 p-0 m-0" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</nav>